---
import { getCollection } from "astro:content";
import Card from "@components/Card";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getSortedProjects from "@utils/getSortedProjects";

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPost = sortedPosts.find(post => post.data.featured);

const projects = await getCollection("projects");
const sortedProjects = getSortedProjects(projects);
const featuredProject = sortedProjects.find(project => project.data.featured);

const archivePosts = sortedPosts.slice(0, 10);
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <img
        src="assets/logo.png"
        alt="SinnaKodern"
        class="hero-logo"
        width="1170"
        height="768"
      />
    </section>
    <Hr />

    {
      (featuredPost || featuredProject) && (
        <section id="featured-content">
          <p class="section-label">Featured</p>
          <ul>
            {featuredPost && (
              <Card
                href={withBase(`posts/${featuredPost.slug}/`)}
                frontmatter={featuredPost.data}
                secHeading={false}
              />
            )}
            {featuredProject && (
              <Card
                href={withBase(`projects/${featuredProject.slug}/`)}
                frontmatter={featuredProject.data}
                secHeading={false}
              />
            )}
          </ul>
        </section>
      )
    }

    <Hr />

    <section id="archive-preview">
      <div class="section-header">
        <div>
          <p class="section-label">Archive</p>
          <h2>Latest articles</h2>
        </div>
        <LinkButton href={withBase("posts/")}>See all archive</LinkButton>
      </div>
      <ul>
        {
          archivePosts.map(({ data, slug }) => (
            <Card href={withBase(`posts/${slug}/`)} frontmatter={data} />
          ))
        }
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply flex justify-center pb-6 pt-8;
  }
  .hero-logo {
    @apply h-auto w-full max-w-3xl;
  }
  #featured-content,
  #archive-preview {
    @apply py-8;
  }
  .section-label {
    @apply mb-2 text-sm uppercase tracking-[0.2em] text-skin-accent opacity-80;
  }
  .section-header {
    @apply mb-4 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between;
  }
  .section-header h2 {
    @apply font-display text-2xl font-semibold tracking-tight;
  }
</style>

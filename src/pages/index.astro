---
import { getCollection } from "astro:content";
import Card from "@components/Card";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import getSortedPosts from "@utils/getSortedPosts";

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPost = sortedPosts[0];
const archivePosts = sortedPosts.slice(0, 10);
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>SinnaKodern</h1>
      <p>
        Welcome. This site contains my development notes, personal resumé/story,
        thoughts on software licensing, and a running archive of projects.
      </p>
      <p>
        Start with the resumé page, then head into licensing notes or the TIL
        section when you want some technical rabbit holes.
      </p>
      <div class="cta-grid">
        <LinkButton href={withBase("resume/")}>The Story / Resumé</LinkButton>
        <LinkButton href={withBase("licensing/")}
          >Thoughts on Licensing</LinkButton
        >
        <LinkButton href={withBase("til/")}>Today I Learned</LinkButton>
        <LinkButton href={withBase("posts/")}>Archive</LinkButton>
      </div>
    </section>
    <Hr />

    {
      featuredPost && (
        <section id="featured-article">
          <p class="section-label">Featured article</p>
          <ul>
            <Card
              href={withBase(`posts/${featuredPost.slug}/`)}
              frontmatter={featuredPost.data}
              secHeading={false}
            />
          </ul>
        </section>
      )
    }

    <Hr />

    <section id="archive-preview">
      <div class="section-header">
        <div>
          <p class="section-label">Archive</p>
          <h2>Latest articles</h2>
        </div>
        <LinkButton href={withBase("posts/")}>See all archive</LinkButton>
      </div>
      <ul>
        {
          archivePosts.map(({ data, slug }) => (
            <Card href={withBase(`posts/${slug}/`)} frontmatter={data} />
          ))
        }
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero p {
    @apply my-2;
  }
  .cta-grid {
    @apply mt-8 grid gap-3 sm:grid-cols-2;
  }
  #featured-article,
  #archive-preview {
    @apply py-8;
  }
  .section-label {
    @apply mb-2 text-sm uppercase tracking-[0.2em] text-skin-accent opacity-80;
  }
  .section-header {
    @apply mb-4 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between;
  }
  .section-header h2 {
    @apply text-2xl font-semibold;
  }
</style>

---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>Weholt Development Labs</h1>
      <p>
        Welcome. This site contains my development notes, personal resumé/story,
        thoughts on software licensing, and a running archive of projects.
      </p>
      <p>
        Start with the resumé page, then head into licensing notes or the TIL
        section when you want some technical rabbit holes.
      </p>
      <div class="cta-grid">
        <LinkButton href={withBase("resume/")}>The Story / Resumé</LinkButton>
        <LinkButton href={withBase("licensing/")}
          >Thoughts on Licensing</LinkButton
        >
        <LinkButton href={withBase("til/")}>Today I Learned</LinkButton>
        <LinkButton href={withBase("posts/")}>Archive</LinkButton>
      </div>
    </section>
    <Hr />
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero p {
    @apply my-2;
  }
  .cta-grid {
    @apply mt-8 grid gap-3 sm:grid-cols-2;
  }
</style>

---
import { getCollection } from "astro:content";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Tag from "@components/Tag.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getUniqueTags from "@utils/getUniqueTags";
import { slugifyStr } from "@utils/slugify";
import { SITE } from "@config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const tags = getUniqueTags(posts);

const withBase = (path: string) =>
  `${import.meta.env.BASE_URL}${path.replace(/^\/+/, "")}`;

const tagsWithPosts = tags.map(({ tag, tagName }) => ({
  tag,
  tagName,
  posts: sortedPosts.filter(post =>
    post.data.tags.some(postTag => slugifyStr(postTag) === tag)
  ),
}));
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header activeNav="tags" />
  <Main
    pageTitle="Tags"
    pageDesc="Browse the archive by tag and jump straight to the topics you care about."
  >
    <section class="tag-overview">
      <p>
        Every tag below links to its own archive page, and each section gives
        you a quick list of the posts filed under that topic.
      </p>
      <ul class="tag-cloud">
        {tags.map(({ tag }) => <Tag {tag} size="lg" />)}
      </ul>
    </section>

    <section class="tag-directory" aria-label="Posts grouped by tag">
      {
        tagsWithPosts.map(({ tag, tagName, posts }) => (
          <article id={tag} class="tag-group">
            <div class="tag-heading-row">
              <h2>
                <a href={withBase(`tags/${tag}/`)}>{tagName}</a>
              </h2>
              <span>
                {posts.length} post{posts.length === 1 ? "" : "s"}
              </span>
            </div>

            <ul class="tag-post-list">
              {posts.map(post => (
                <li>
                  <a href={withBase(`posts/${post.slug}/`)}>
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>
  </Main>
  <Footer />
</Layout>

<style>
  .tag-overview p {
    @apply mb-4;
  }

  .tag-cloud {
    @apply mb-10;
  }

  .tag-directory {
    @apply grid gap-8;
  }

  .tag-group {
    @apply rounded-lg border border-skin-line bg-skin-card bg-opacity-30 p-5;
    scroll-margin-top: 2rem;
  }

  .tag-heading-row {
    @apply mb-4 flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between;
  }

  .tag-heading-row h2 {
    @apply font-display text-2xl font-semibold tracking-tight;
  }

  .tag-heading-row h2 a {
    @apply hover:text-skin-accent;
  }

  .tag-heading-row span {
    @apply text-sm uppercase tracking-[0.18em] text-skin-accent opacity-80;
  }

  .tag-post-list {
    @apply grid gap-2;
  }

  .tag-post-list a {
    @apply underline decoration-dashed underline-offset-4 hover:text-skin-accent;
  }
</style>
